{
  "manifest_version": 3,
  "name": "gTabs - AI Tab Organizer",
  "version": "0.3.1",
  "description": "One-click AI tab organizer with editable suggestions, undo, and local or cloud LLM support",
  "permissions": ["tabs", "tabGroups", "storage", "alarms", "contextMenus"],
  "host_permissions": [
    "https://api.openai.com/*",
    "https://api.anthropic.com/*",
    "https://openrouter.ai/*",
    "https://api.groq.com/*",
    "https://api.x.ai/*",
    "http://localhost:11434/*"
  ],
  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "background": {
    "service_worker": "background.js"
  },
  "commands": {
    "organize-tabs": {
      "suggested_key": { "default": "Ctrl+Shift+G", "mac": "Command+Shift+G" },
      "description": "Organize tabs into groups"
    },
    "undo-grouping": {
      "suggested_key": { "default": "Ctrl+Shift+Z", "mac": "Command+Shift+Z" },
      "description": "Undo last tab grouping"
    }
  },
  "options_page": "options.html",
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}
